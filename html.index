<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <title>AI German–French Cuisine Generator</title>
    <link rel="stylesheet" href="style.css" />
  </head>

  <body>
    <div class="container">
      <h1>AI German–French Cuisine Generator</h1>

      <form id="dish-form">
        <label>Enter your instructions:</label>
        <input
          type="text"
          id="user-instructions"
          placeholder="Example: Create a new German–French fusion dish with chicken"
          required
        />
        <button type="submit">Generate Dish</button>
      </form>

      <div id="result"></div>

      <footer>
        <p>
          Coded by Kristian •
          <a href="YOUR_GITHUB_REPO_URL" target="_blank">GitHub</a>
        </p>
      </footer>
    </div>

    <script src="script.js"></script>
  </body>
</html>
